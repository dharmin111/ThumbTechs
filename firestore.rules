rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    function isCustomer(userId) {
      return isLoggedIn() && request.auth.uid == userId;
    }

    function isTechnician() {
      return isLoggedIn() && 
             (request.auth.token.role == 'technician' || 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'technician');
    }

    // ================= USERS =================
    match /users/{userId} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn() && request.auth.uid == userId;
    }

    // ================= CUSTOMERS =================
    match /customers/{userId} {
      allow read, write: if isCustomer(userId);
    }

    // ================= TECHNICIANS =================
    match /technicians/{userId} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn() && request.auth.uid == userId;
    }

    // ================= SERVICES =================
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isLoggedIn();
    }

    // ================= BOOKINGS =================
    match /bookings/{bookingId} {
      allow read, write: if isLoggedIn();
    }

    // ================= SERVICE REQUESTS =================
    match /service_requests/{requestId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isLoggedIn();
    }

    // ================= NOTIFICATIONS =================
    match /notifications/{notificationId} {
      allow read: if isLoggedIn() && resource.data.userId == request.auth.uid;
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && resource.data.userId == request.auth.uid;
    }

    // ================= CONVERSATIONS =================
    match /conversations/{conversationId} {
      // Allow create for any logged-in user
      allow create: if isLoggedIn();
      
      // For read and update, check if document exists first
      allow read: if isLoggedIn() && (
        !exists(/databases/$(database)/documents/conversations/$(conversationId)) ||
        resource.data.customerId == request.auth.uid || 
        resource.data.technicianId == request.auth.uid
      );
      
      allow update: if isLoggedIn() && (
        !exists(/databases/$(database)/documents/conversations/$(conversationId)) ||
        resource.data.customerId == request.auth.uid || 
        resource.data.technicianId == request.auth.uid
      );
      
      allow delete: if false;
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isLoggedIn();
        allow create: if isLoggedIn();
        allow update: if isLoggedIn() && resource.data.receiverId == request.auth.uid;
        allow delete: if false;
      }
    }
  }
}